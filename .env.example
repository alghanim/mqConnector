# mqConnector docker-compose env file.
# Copy to .env and edit before `docker compose up`.
# Every var below is consumed by docker-compose.yml; the runtime env vars that
# mqconnector itself reads (SERVER_LISTEN, AUTH_SIMPLEAUTH_URL, etc.) are set
# inside the compose file from these values.

# ------ mqConnector ----------------------------------------------------------
MQC_VERSION=1.0.0
MQC_HOST_PORT=8443       # host-side port mapped to the container's 8443
MQC_MODE=dev             # "dev" or "prod". In prod the compose file mounts a real cert.
MQC_LOG_LEVEL=info       # debug|info|warn|error
MQC_LOG_FORMAT=json      # json|text

# When MQC_MODE=prod, populate these to bind real TLS material. In dev mode
# the cert is auto-generated by the certs-init service.
MQC_TLS_CERT=./certs/server.crt
MQC_TLS_KEY=./certs/server.key

# ------ SimpleAuth -----------------------------------------------------------
# Path to the sibling SimpleAuth checkout used as the docker build context.
# Override only if your local layout differs.
SIMPLEAUTH_CONTEXT=../SimpleAuth
SIMPLEAUTH_HOST_PORT=9443     # host-side port mapped to the container's 8080
SIMPLEAUTH_VERSION=docker

# Initial admin credentials. The bootstrap container creates this user
# via SimpleAuth's admin API on first boot. Password must meet SimpleAuth's
# default policy: ≥8 chars with at least one upper, one lower, one digit,
# and one special character.
SIMPLEAUTH_ADMIN_USER=admin
SIMPLEAUTH_ADMIN_PASSWORD=Changeme1!

# Admin API bearer token used by the bootstrap container (and any out-of-band
# admin scripts) to talk to SimpleAuth. Generate a strong random value in
# production: `openssl rand -hex 32`.
SIMPLEAUTH_ADMIN_KEY=dev-admin-key-changeme

# ------ RabbitMQ -------------------------------------------------------------
RABBITMQ_DEFAULT_USER=mqc
RABBITMQ_DEFAULT_PASS=mqc-dev
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ------ Kafka (KRaft mode — no Zookeeper) ------------------------------------
KAFKA_HOST_PORT=9092
KAFKA_CLUSTER_ID=mqc-local-cluster
