# Build artifacts. The `mqconnector` binary (and OS-suffixed variants) is
# produced into /dist/ by scripts/build.sh, but a quick `go build` puts it
# at the repo root. The leading slashes anchor these rules to the root so
# they don't accidentally exclude the cmd/mqconnector/ package directory.
/dist/
/build/
/out/
/bin/
/mqconnector
/mqconnector-*

# Test artifacts
*.test
*.out
coverage.txt
coverage.html

# Go workspace
go.work
go.work.sum

# Runtime data
/data/
/data.db
/data.db-*
*.sqlite
*.sqlite-*

# Local config and secrets
config.yaml
config.local.yaml
.env
.env.local
*.pem
*.key
*.crt
!config.example.yaml

# Frontend
web/node_modules/
web/.svelte-kit/
web/build/
web/.env
web/.env.*
!web/.env.example

# Embedded frontend dist (populated by build)
internal/web/dist/*
!internal/web/dist/.gitkeep

# Editor / OS
.DS_Store
*.swp
.idea/
*.iml

# Logs
*.log
.claude/worktrees/
