{
  "title": "mqConnector \u2014 Overview",
  "uid": "mqc-overview",
  "schemaVersion": 38,
  "version": 1,
  "timezone": "browser",
  "tags": [
    "mqconnector",
    "operations"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "pipeline_id",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(mqconnector_messages_processed_total, pipeline_id)",
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Active pipelines",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(count by (pipeline_id) (mqconnector_messages_processed_total))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "title": "Uptime",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "mqconnector_uptime_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "type": "stat",
      "title": "Msg / sec (5m rate)",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(mqconnector_messages_processed_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 1
        }
      }
    },
    {
      "type": "stat",
      "title": "Fail rate (5m)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "1 - avg(mqconnector:availability:ratio5m)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.001
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Throughput per pipeline (msg/s)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (pipeline_id) (rate(mqconnector_messages_processed_total{pipeline_id=~\"$pipeline_id\"}[1m]))",
          "legendFormat": "{{pipeline_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Failures per pipeline (msg/s)",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (pipeline_id) (rate(mqconnector_messages_failed_total{pipeline_id=~\"$pipeline_id\"}[1m]))",
          "legendFormat": "{{pipeline_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Avg latency (ms)",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "mqconnector_avg_latency_ms{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "{{pipeline_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 2000
              }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Bytes processed (per second)",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (pipeline_id) (rate(mqconnector_bytes_processed_total{pipeline_id=~\"$pipeline_id\"}[1m]))",
          "legendFormat": "{{pipeline_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      }
    },
    {
      "type": "gauge",
      "title": "Availability SLO \u2014 1h",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "avg(mqconnector:availability:ratio1h)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0.99,
          "max": 1.0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.999
              },
              {
                "color": "green",
                "value": 0.9995
              }
            ]
          }
        }
      }
    },
    {
      "type": "gauge",
      "title": "Availability SLO \u2014 6h",
      "gridPos": {
        "x": 8,
        "y": 20,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "avg(mqconnector:availability:ratio6h)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0.99,
          "max": 1.0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.999
              },
              {
                "color": "green",
                "value": 0.9995
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Error budget burn (1h vs weekly)",
      "gridPos": {
        "x": 16,
        "y": 20,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "(1 - avg(mqconnector:availability:ratio1h)) / (1 - 0.999)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 6
              }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "p95 latency (ms)",
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "mqconnector:latency_ms:p95{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "{{pipeline_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1000
              },
              {
                "color": "red",
                "value": 3000
              }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "p99 latency (ms)",
      "gridPos": {
        "x": 12,
        "y": 26,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "mqconnector:latency_ms:p99{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "{{pipeline_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2000
              },
              {
                "color": "red",
                "value": 5000
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Pipeline status (1 = up, 0 = error/stopped)",
      "gridPos": {
        "x": 0,
        "y": 34,
        "w": 24,
        "h": 5
      },
      "targets": [
        {
          "expr": "mqconnector_pipeline_up{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "{{pipeline_id}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "value_and_name"
      }
    },
    {
      "type": "row",
      "title": "Operational health (Phase 2)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 39,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "DLQ depth per pipeline",
      "description": "mqconnector_dlq_depth \u2014 number of dead-lettered messages per pipeline. Alerts on sustained growth (mqConnectorDLQGrowing).",
      "gridPos": {
        "x": 0,
        "y": 40,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "mqconnector_dlq_depth{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "{{pipeline_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "type": "timeseries",
      "title": "DLQ oldest age (seconds)",
      "description": "mqconnector_dlq_oldest_age_seconds \u2014 age of the longest-resident DLQ row. >1h triggers mqConnectorDLQStuck.",
      "gridPos": {
        "x": 12,
        "y": 40,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "mqconnector_dlq_oldest_age_seconds{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "{{pipeline_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Source backlog (broker-side)",
      "description": "mqconnector_source_depth \u2014 RabbitMQ queue depth or Kafka consumer-group lag, sampled every 30s by the depth-sampler. Series absent = source type doesn't expose depth (NATS Core, MQTT QoS 0).",
      "gridPos": {
        "x": 0,
        "y": 48,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "mqconnector_source_depth{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "{{pipeline_id}} ({{source}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "type": "stat",
      "title": "Leader (HA only)",
      "description": "mqconnector_leader \u2014 1 if this replica holds the leadership lease, 0 otherwise. In a single-process deploy the mode label is 'single' and this is always 1.",
      "gridPos": {
        "x": 12,
        "y": 48,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "mqconnector_leader",
          "legendFormat": "{{self}} ({{mode}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "value_and_name"
      }
    },
    {
      "type": "stat",
      "title": "Lease remaining (s)",
      "description": "mqconnector_leader_lease_remaining_seconds \u2014 countdown to the next renewal deadline. Should hover near ttl/2; sustained <5s warns via mqConnectorLeaderLeaseExpiringFast.",
      "gridPos": {
        "x": 18,
        "y": 48,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "mqconnector_leader_lease_remaining_seconds",
          "legendFormat": "{{self}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        }
      }
    },
    {
      "type": "stat",
      "title": "Master key version",
      "description": "mqconnector_master_key_version \u2014 current AES-GCM key version. 0 means encryption disabled (prod refuses to start in this state); >1 indicates active rotation history.",
      "gridPos": {
        "x": 12,
        "y": 52,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "expr": "mqconnector_master_key_version",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "value"
      }
    }
  ]
}